{
  "extends": "@repo/typescript-config/library.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": "./src",
    "types": ["node"],
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "**/*.test.ts", "**/*.spec.ts"]
}
