# LotusGift v2 — production environment template (Oracle A1.Flex VM).
#
# Copy to /opt/lotusgift/.env.production and fill in the placeholders.
# NEVER commit the populated file. The compose stack picks this up via the
# env_file directive in compose/docker-compose.prod.yml.
#
# Provenance comments indicate the phase that introduces each variable, so
# values can stay empty (or commented) until the consuming service exists.
#
# Apply:
#   sudo install -m 0640 -o ubuntu -g ubuntu \
#        infrastructure/oracle/.env.production.example \
#        /opt/lotusgift/.env.production
#   sudo $EDITOR /opt/lotusgift/.env.production    # fill the values
#
# Audit (without leaking values):
#   sudo awk -F= '/^[A-Z]/ {print $1}' /opt/lotusgift/.env.production | sort

# ----------------------------------------------------------------------------
# Runtime basics
# ----------------------------------------------------------------------------
# provenance: PR-7
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Public-facing FQDN (matches nginx server_name + Better-Auth trusted-origin).
# provenance: PR-7
LOTUSGIFT_API_HOST=api.lotusgift.com

# GHCR repository owner — used by compose to resolve the image reference. The
# default (goldr0g3r) is the canonical PR-7 location; override if you fork.
# provenance: PR-7
LOTUSGIFT_GHCR_OWNER=goldr0g3r

# Image tag — overridden by deploy.sh on every release.
# provenance: PR-7
IMAGE_TAG=main

# ----------------------------------------------------------------------------
# Datastores (off-VM)
# ----------------------------------------------------------------------------
# MongoDB Atlas M0 (AWS Mumbai). Get the connection string from the Atlas UI;
# replace <username>, <password>, and the cluster hostname.
# provenance: P3
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/lotusgift?retryWrites=true&w=majority

# Upstash Redis (AWS Mumbai). Use the rediss:// (TLS) URL from the Upstash
# console.
# provenance: P3
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ----------------------------------------------------------------------------
# Auth (Better-Auth)
# ----------------------------------------------------------------------------
# 32+ char random secret used for session signing.
# Generate with: openssl rand -base64 32
# provenance: P5
BETTER_AUTH_SECRET=

# Trusted origin for auth cookies (matches LOTUSGIFT_API_HOST).
# provenance: P5
BETTER_AUTH_URL=https://api.lotusgift.com

# Cross-subdomain cookie for the 4 Next apps (web-customer/vendor/admin/cs).
# provenance: P5
BETTER_AUTH_COOKIE_DOMAIN=.lotusgift.com

# ----------------------------------------------------------------------------
# Observability
# ----------------------------------------------------------------------------
# OTLP HTTP endpoint to Grafana Cloud — leave blank in PR-7 (the api-gateway
# logs to stdout only until P21 wires up the real exporters).
# provenance: P21
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_SERVICE_NAME=lotusgift-api-gateway

# Sentry DSN — populated at P3 alongside the observability bootstrap.
# provenance: P3
SENTRY_DSN=

# PostHog Cloud EU — analytics + feature flags, populated at P3b.
# provenance: P3b
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ----------------------------------------------------------------------------
# File storage (Cloudflare R2)
# ----------------------------------------------------------------------------
# provenance: P7 (catalog images) + P8b (customization art files)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_PUBLIC=lotusgift-catalog
R2_BUCKET_PRIVATE=lotusgift-customization

# ----------------------------------------------------------------------------
# Payments (Razorpay)
# ----------------------------------------------------------------------------
# Live keys (NOT test keys) for the production environment. Razorpay webhook
# secret is used to verify HMAC-SHA256 signatures in payment-service.
# provenance: P10
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ----------------------------------------------------------------------------
# Shipping carriers
# ----------------------------------------------------------------------------
# provenance: P11
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=
DELHIVERY_API_TOKEN=
BLUEDART_API_KEY=
BLUEDART_LICENSE_KEY=

# ----------------------------------------------------------------------------
# Notifications
# ----------------------------------------------------------------------------
# provenance: P12
RESEND_API_KEY=
MSG91_AUTH_KEY=
MSG91_SENDER_ID=
WHATSAPP_API_KEY=

# ----------------------------------------------------------------------------
# Tax / GST
# ----------------------------------------------------------------------------
# IRP e-invoice credentials (provided by the GSP — chosen at P13 research).
# provenance: P13
IRP_GSP_BASE_URL=
IRP_GSP_USERNAME=
IRP_GSP_PASSWORD=
IRP_GSP_CLIENT_ID=
IRP_GSP_CLIENT_SECRET=
