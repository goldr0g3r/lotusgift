{
  "name": "@repo/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles/*": "./src/*"
  },
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test --config=playwright-ct.config.ts"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.2.4",
    "@repo/design-tokens": "workspace:*",
    "clsx": "^2.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/experimental-ct-react": "^1.60.0",
    "@playwright/test": "^1.60.0",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.15.3",
    "@types/react": "19.1.0",
    "@types/react-dom": "19.1.1",
    "axe-core": "^4.11.4",
    "eslint": "^9.31.0",
    "jsdom": "^29.1.1",
    "sass": "^1.99.0",
    "typescript": "5.9.2",
    "vitest": "^3.2.4",
    "vitest-axe": "^0.1.0"
  }
}
