# LotusGift v2 environment-variable template.
#
# Per .cursor/rules/secrets-and-secrets-handling.mdc: this file is the
# only `.env*` committed (names only, NEVER values). Real values live in
# GitHub Environments (CI), Vercel (frontend), and Oracle systemd
# `EnvironmentFile=` (backend VM).
#
# Schema source of truth: packages/config/src/env.schema.ts.

# ---- Core runtime ----
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ---- MongoDB ----
MONGODB_URI=mongodb://localhost:27017/lotusgift

# ---- Better-Auth (P5) ----
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# ---- Frontend CORS allow-list (comma-separated for multi-origin) ----
FRONTEND_URL=http://localhost:3000
FRONTEND_URLS=

# ---- Razorpay (P10) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- SMTP / Resend (P12) ----
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# ---- MSG91 (P5b phone OTP) ----
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=

# ---- Google OAuth (P5b social provider) ----
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Upstash Redis (P4 rate-limit, P8 inventory reservations) ----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Cloudflare R2 (P7 images, P8b customization art) ----
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_ENDPOINT=

# ---- Cloudflare R2 product images (P7 product-service) ----
# Per Cloudflare R2 docs <https://developers.cloudflare.com/r2/api/s3/presigned-urls/>:
# region = 'auto', endpoint = 'https://<ACCOUNT_ID>.r2.cloudflarestorage.com',
# presigned PUT URLs cap at 7-day expiry; product-service uses 15 min (900s)
# per phase-7 D17. R2_PUBLIC_BASE_URL points at the public CDN-fronted bucket
# domain (configured separately at the Cloudflare R2 dashboard).
R2_BUCKET_PRODUCT_IMAGES=
R2_PRESIGN_EXPIRY_SECONDS=900
R2_MAX_IMAGE_SIZE_BYTES=5242880
R2_PUBLIC_BASE_URL=

# ---- OpenTelemetry -> Grafana Cloud (P3) ----
OTEL_SERVICE_NAME=lotusgift-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# ---- Pino logger (P3) ----
PINO_REDACT_FIELDS=

# ---- OutboxPort relayer (P3) ----
OUTBOX_POLL_INTERVAL_MS=250

# ---- OSM Nominatim (P6 vendor-service warehouse geocoding) ----
# Per OSM policy <https://operations.osmfoundation.org/policies/nominatim/>:
# 1 absolute req/sec, results must be cached, User-Agent must identify the app.
# Override NOMINATIM_BASE_URL to point at a self-hosted instance (recommended for
# production); see docs/runbooks/scaling-up.md for the MapMyIndia upgrade path.
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_USER_AGENT=LotusGift-v2-Dev/0.1
GEOCODE_CACHE_TTL_SECONDS=86400
